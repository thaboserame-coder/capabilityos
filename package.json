{
  "name": "capabilityos",
  "version": "0.1.0",
  "private": true,
  "description": "CapabilityOS - Digilytics Workforce Intelligence Platform (enterprise AI literacy learning experience)",
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "e2e": "start-server-and-test preview http://localhost:4173 cypress:run",
    "e2e:percy": "start-server-and-test preview http://localhost:4173 'percy exec -- cypress run'",
    "prepare": "husky install"
  },
  "dependencies": {
    "lucide-react": "^0.383.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.0",
    "@eslint/js": "^9.9.1",
    "@percy/cli": "^1.30.1",
    "@percy/cypress": "^3.1.2",
    "@storybook/addon-a11y": "^8.3.5",
    "@storybook/addon-essentials": "^8.3.5",
    "@storybook/addon-interactions": "^8.3.5",
    "@storybook/blocks": "^8.3.5",
    "@storybook/react": "^8.3.5",
    "@storybook/react-vite": "^8.3.5",
    "@storybook/test": "^8.3.5",
    "@testing-library/cypress": "^10.0.2",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.1",
    "axe-core": "^4.10.0",
    "cypress": "^13.14.2",
    "cypress-axe": "^1.5.0",
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.9.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "eslint-plugin-storybook": "^0.11.2",
    "globals": "^15.9.0",
    "husky": "^9.1.6",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.3",
    "start-server-and-test": "^2.0.8",
    "storybook": "^8.3.5",
    "vite": "^5.4.2",
    "vitest": "^2.1.1",
    "web-vitals": "^5.3.0"
  }
}
