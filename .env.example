# Copy this file to .env.local for local development (never commit .env*
# files with real values — see .gitignore).

# --- Serverless function (api/quiz.js), server-side only -------------------
# Anthropic API key used to generate AI-tailored module quizzes. If unset,
# /api/quiz returns 503 and the client falls back to the local question bank
# (src/data/fallbackQuiz.js) — the app remains fully usable without this.
ANTHROPIC_API_KEY=

# --- Client-side observability (src/observability/*), optional -------------
# Endpoint that receives POSTed Core Web Vitals (LCP, CLS, INP, FCP, TTFB) as
# JSON. Leave unset to only log metrics to the console in development.
VITE_ANALYTICS_ENDPOINT=

# Endpoint that receives POSTed uncaught-error/unhandled-rejection reports as
# JSON. Leave unset to only log errors to the console in development.
VITE_ERROR_ENDPOINT=
